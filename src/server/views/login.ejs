<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>Log In — HCS Sync</title>
    <link rel="stylesheet" href="/static/styles.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
    <script>
      if (localStorage.getItem('color-theme') === 'dark' || (!('color-theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
  </head>
  <body class="min-h-screen bg-gray-50 dark:bg-gray-900 flex items-center justify-center px-4">

<div class="max-w-md mx-auto py-10 px-4">
    <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">
        <!-- Blue accent bar -->
        <div class="h-1.5 bg-gradient-to-r from-blue-500 to-blue-400"></div>

        <div class="p-8">
          <h1 class="text-2xl font-bold text-center text-gray-900 dark:text-gray-100 mb-6">Log in</h1>
          <% if (skipTurnstile) { %>
          <div class="mb-4 p-3 rounded-xl bg-amber-50 dark:bg-amber-900/30 text-amber-800 dark:text-amber-300 text-sm border border-amber-200 dark:border-amber-800">
            CAPTCHA bypass is active (SKIP_TURNSTILE=true). Do not enable this in production.
          </div>
          <% } %>

          <% if (error) { %>
          <div class="mb-4 p-3 rounded-xl bg-red-50 dark:bg-red-900/30 text-red-800 dark:text-red-300 text-sm border border-red-200 dark:border-red-800" role="alert">
            <%= error %>
          </div>
          <% } %>

          <form action="/login" method="POST" class="space-y-6">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <input type="hidden" name="next" value="<%= next %>" />

            <!-- Username or Email -->
            <div>
              <label for="username" class="block mb-1 text-sm font-medium text-gray-700 dark:text-gray-300">
                Username or Email:
              </label>
              <input
                type="text"
                id="username"
                name="username"
                required
                autofocus
                autocomplete="username"
                class="w-full px-4 py-2.5 border border-gray-200 dark:border-gray-700 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-gray-100"
              >
            </div>

            <!-- Password -->
            <div>
              <label for="password" class="block mb-1 text-sm font-medium text-gray-700 dark:text-gray-300">
                Password:
              </label>
              <input
                type="password"
                id="password"
                name="password"
                required
                autocomplete="current-password"
                class="w-full px-4 py-2.5 border border-gray-200 dark:border-gray-700 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-gray-100"
              >
            </div>

            <!-- Turnstile (hidden when bypass active) -->
            <% if (skipTurnstile) { %>
            <input type="hidden" name="cf-turnstile-response" value="bypassed" />
            <% } else { %>
            <div>
              <div class="cf-turnstile" data-sitekey="<%= siteKey %>"></div>
            </div>
            <% } %>

            <!-- Submit -->
            <div class="flex flex-col sm:flex-row justify-between items-center gap-4 pt-4">
              <button type="submit"
                class="w-full sm:w-auto inline-flex items-center justify-center gap-1.5 px-6 py-2.5 rounded-lg text-sm font-medium bg-blue-600 text-white hover:bg-blue-700 transition shadow-sm">
                <i class="bi bi-box-arrow-in-right"></i> Log in
              </button>
            </div>
          </form>
        </div>
    </div>
</div>

  </body>
</html>
