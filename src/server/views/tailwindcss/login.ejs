<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
<div class="max-w-md mx-auto py-10 px-4">
  <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">
    <!-- Blue accent bar -->
    <div class="h-1.5 bg-gradient-to-r from-blue-600 to-blue-400"></div>
    <div class="p-8">
      <h1 class="text-2xl font-bold text-center text-gray-900 dark:text-gray-100 mb-6">Log in</h1>
      <% if (skipTurnstile) { %>
        <div
          class="mb-4 p-3 rounded-xl bg-amber-50 dark:bg-amber-900/30 text-amber-800 dark:text-amber-300 text-sm border border-amber-200 dark:border-amber-800">
          CAPTCHA bypass is active (SKIP_TURNSTILE=true). Do not enable this in production.
        </div>
        <% } %>
          <form action="/login" method="POST" class="space-y-6">
            <%- include('./partials/csrfHidden.ejs') %>
              <input type="hidden" name="next" value="<%= next %>">

              <!-- Username or Email -->
              <div>
                <label for="username" class="block mb-1 text-sm font-medium text-gray-700 dark:text-gray-300">
                  Username or Email:
                </label>
                <input type="text" id="username" name="username" required autofocus autocomplete="username"
                  class="w-full px-4 py-2.5 border border-gray-200 dark:border-gray-700 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-gray-100">
              </div>

              <!-- Password -->
              <div>
                <label for="password" class="block mb-1 text-sm font-medium text-gray-700 dark:text-gray-300">
                  Password:
                </label>
                <input type="password" id="password" name="password" required autocomplete="current-password"
                  class="w-full px-4 py-2.5 border border-gray-200 dark:border-gray-700 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-gray-100">
              </div>

              <!-- 2FA code (required only for accounts with TOTP enabled) -->
              <div>
                <label for="totp" class="block mb-1 text-sm font-medium text-gray-700 dark:text-gray-300">
                  Two-factor code <span class="text-gray-400 dark:text-gray-500 font-normal">(if enabled)</span>
                </label>
                <input type="text" id="totp" name="totp" inputmode="numeric" pattern="[0-9]*" maxlength="6"
                  autocomplete="one-time-code" placeholder="123456"
                  class="w-full px-4 py-2.5 border border-gray-200 dark:border-gray-700 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-gray-100">
              </div>

              <!-- Turnstile CAPTCHA -->
              <% if (skipTurnstile) { %>
                <input type="hidden" name="cf-turnstile-response" value="bypassed">
                <% } else { %>
                  <div>
                    <div class="cf-turnstile" data-sitekey="<%= siteKey %>"></div>
                  </div>
                  <% } %>

                    <!-- Submit / Register Buttons -->
                    <div class="flex flex-col sm:flex-row justify-between items-center gap-4 pt-4">
                      <button type="submit"
                        class="w-full sm:w-auto inline-flex items-center justify-center gap-1.5 px-6 py-2.5 rounded-lg text-sm font-medium bg-blue-600 text-white hover:bg-blue-700 transition shadow-sm focus:ring-4 focus:ring-blue-300 dark:focus:ring-blue-800">
                        <i class="bi bi-box-arrow-in-right"></i> Log in
                      </button>
                      <a href="https://app.heroncs.co.uk/user/register"
                        class="w-full sm:w-auto inline-flex items-center justify-center gap-1.5 text-center text-sm font-medium border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 px-6 py-2.5 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 transition">
                        <i class="bi bi-book"></i> Create an account
                      </a>
                    </div>
                    <div class="text-center pt-2">
                      <a href="https://app.heroncs.co.uk/user/forgot-password"
                        class="text-sm text-blue-600 dark:text-blue-400 hover:underline">
                        Forgot your password?
                      </a>
                    </div>
          </form>
    </div>
  </div>
</div>