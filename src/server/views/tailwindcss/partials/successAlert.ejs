<% if (typeof flash !== 'undefined' && flash && flash.success && flash.success.length > 0) { %>
  <% flash.success.forEach(function(message, index) { %>
    <div
      id="successToast<%= index %>"
      class="fixed bottom-20 right-4 mb-3 p-4 bg-blue-600 dark:bg-blue-700 text-white rounded-xl shadow-lg flex items-center space-x-4 max-w-xs z-[60]"
      role="alert" aria-live="assertive" aria-atomic="true"
    >
      <div class="flex-1">
        <%= message %>
      </div>
      <button
        type="button"
        aria-label="Close"
        class="text-white hover:text-blue-200 dark:hover:text-blue-300 focus:outline-none"
        data-dismiss-target="successToast<%= index %>"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  <% }); %>

  <script nonce="<%= locals.cspNonce %>">
    window.addEventListener('load', function () {
      document.querySelectorAll('[id^="successToast"]').forEach(toast => {
        setTimeout(() => { toast.remove(); }, 4000);
      });
    });
  </script>
<% } %>
