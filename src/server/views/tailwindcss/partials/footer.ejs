<footer class="w-full text-xs text-gray-600 dark:text-gray-400 py-2 border-t border-gray-200 dark:border-gray-700 bg-white/80 dark:bg-gray-800/80 backdrop-blur-md shadow-sm">
  <div class="max-w-7xl mx-auto flex flex-wrap justify-between items-center gap-x-4 gap-y-1 px-2 text-[0.75rem] leading-snug">
    <div>
      <% if (appBuild?.version) { %>
        <small class="cursor-default">v<%= appBuild.version %><% if (appBuild?.commit) { %> &bull; <%= appBuild.branch ? (appBuild.branch + '@') : '' %><%= appBuild.commit %><% } %></small>
      <% } %>
    </div>
    <div class="flex items-center space-x-2">
      <small>&copy; <%= new Date().getFullYear() %></small>
      <a href="https://www.heroncs.co.uk" class="text-blue-600 hover:underline whitespace-nowrap">
        Heron Constructive Solutions LTD
      </a>
    </div>
    <div class="flex items-center space-x-2">
      <small>
        <a href="https://beta.companieshouse.gov.uk/company/09276951" class="text-blue-600 hover:underline">
          Company: 09276951
        </a>
      </small>
    </div>
  </div>
  <!-- Toast container -->
  <div id="toast-container" class="fixed top-4 right-4 z-50 space-y-2"></div>
</footer>
