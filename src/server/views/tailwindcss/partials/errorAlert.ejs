<% if (typeof flash !== 'undefined' && flash && flash.error && flash.error.length > 0) { %>
  <div class="fixed top-20 right-4 space-y-4 z-[60]">
    <% flash.error.forEach(function(message, index) { %>
      <div id="errorToast<%= index %>"
        class="relative flex items-start bg-red-600 dark:bg-red-700 text-white rounded-lg shadow-lg px-4 py-3 max-w-xs animate-slide-in">
        <div class="flex-1 pr-6">
          <p class="text-sm"><%= message %></p>
        </div>
        <button
          class="absolute top-2 right-2 text-white hover:text-red-200 dark:hover:text-red-300 focus:outline-none"
          data-dismiss-target="errorToast<%= index %>"
          aria-label="Close">
          <i class="bi bi-x-lg"></i>
        </button>
      </div>
    <% }); %>
  </div>

  <style>
    @keyframes slide-in {
      from { opacity: 0; transform: translateY(-10px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .animate-slide-in { animation: slide-in 0.3s ease-out; }
  </style>

  <script>
    window.addEventListener('load', function () {
      document.querySelectorAll('[id^="errorToast"]').forEach(toast => {
        setTimeout(() => { toast.remove(); }, 5000);
      });
    });
  </script>
<% } %>
