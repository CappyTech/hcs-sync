SESSION_TOKEN=
USERNAME=
PASSWORD=
MEMORABLE_WORD=
BASE_URL=
HTTP_TIMEOUT_MS=30000
CONCURRENCY=4
# Concurrency for fetching entity details (default: same as CONCURRENCY)
# DETAIL_CONCURRENCY=4
PORT=3000

# Logging
# Log level: fatal | error | warn | info | debug | trace (default: info)
# LOG_LEVEL=info
# Set to true to enable pretty-printed pino logs (dev only)
# PINO_PRETTY=false
# Maximum number of sync run log entries to retain (default: 100)
# RUN_LOG_MAX_ENTRIES=100

# Cron (optional)
# When enabled, the container will run syncs on a schedule and manual dashboard runs are blocked.
CRON_ENABLED=false
# Standard 5-field cron expression (min hour day month day-of-week)
# Default is hourly at minute 0.
CRON_SCHEDULE=0 * * * *
# Optional IANA timezone. Defaults to Europe/London if unset.
CRON_TIMEZONE=
# Optional: mark /cron/health unhealthy if there's no cron activity within this window.
# Set 0 to disable staleness checks.
CRON_HEALTH_STALE_MS=0

# Discord alerts (optional)
# When set, sync posts a Discord embed on FAILED runs and on successful runs that
# CHANGED data (no-op successes stay silent). Leave blank to disable alerting.
# Use a dedicated #sync-alerts webhook, separate from the backup-alert webhook.
DISCORD_WEBHOOK_URL=

# MongoDB (optional; if not set, sync runs in fetch-only mode)
MONGO_URI=
MONGO_HOST=
MONGO_PORT=27017
MONGO_DB_NAME=kashflow
MONGO_USERNAME=
MONGO_PASSWORD=
# Optional; common value is 'admin' when using a root user
MONGO_AUTH_SOURCE=

# SSO (required to protect the UI behind hcs-app login)
# hcs-app issues cookie `hcs_sso` and hcs-sync verifies it.
# hcs-sync's login form calls hcs-app's token endpoint using HCS_SYNC_API_KEY.
# HCS_SYNC_API_KEY also protects the machine-to-machine POST /api/pull endpoint
# (sent as the X-Sync-Api-Key header), which hcs-app calls to re-sync a single
# entity from KashFlow on demand.
HCS_APP_BASE_URL=https://app.heroncs.co.uk
HCS_SSO_JWT_SECRET=
HCS_SYNC_API_KEY=
# Set to .heroncs.co.uk in production
HCS_SSO_COOKIE_DOMAIN=

# Cloudflare Turnstile (optional — set both keys to enable CAPTCHA on login)
# Get keys from https://dash.cloudflare.com/ → Turnstile
# Leave blank (or set SKIP_TURNSTILE=true) to disable in dev.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# SKIP_TURNSTILE=true

# Tailscale (optional)
# If set, the container joins your tailnet on startup using userspace networking.
# Generate an auth key at https://login.tailscale.com/admin/settings/keys
# Leave unset to skip Tailscale entirely.
# TS_AUTHKEY=
# Override the hostname this container registers on the tailnet (default: hcs-sync)
# TS_HOSTNAME=hcs-sync